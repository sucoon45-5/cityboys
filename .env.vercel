# Vercel Environment Variables
# Copy these into the Vercel Dashboard Settings > Environment Variables

# Database Connection (Get these from your cloud MySQL provider)
DB_HOST=your-cloud-db-host.com
DB_USER=your-db-username
DB_PASS=your-db-password
DB_NAME=your-db-name
DB_SSL=true

# Security
JWT_SECRET=generate-a-long-random-string-here

# Environment
NODE_ENV=production
VERCEL=1
